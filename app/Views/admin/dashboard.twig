{% extends "layout.twig" %}
{% block content %}
<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h3 fw-bold"><i class="bi bi-speedometer2 me-2 text-danger"></i>Dashboard</h1>
    <small class="text-muted">Panel de Control</small>
</div>

{% if modules is empty %}
<div class="text-center py-5 text-muted">
    <i class="bi bi-database-slash" style="font-size:3rem;"></i>
    <h4 class="mt-3">Sin módulos generados</h4>
    <p>Crea una migración y ejecuta <code>php dash migrate</code> para generar tus primeros módulos.</p>
</div>
{% else %}
<div class="row g-4">
    {% for mod in modules %}
    <div class="col-sm-6 col-lg-4">
        <a href="/admin/{{ mod.name }}" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #e94560 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div style="background:#e945601a; border-radius:12px; padding:14px;">
                        <i class="bi bi-table text-danger" style="font-size:1.6rem;"></i>
                    </div>
                    <div>
                        <div class="text-muted small text-uppercase fw-semibold">{{ mod.name }}</div>
                        <div class="fs-3 fw-bold text-dark">{{ mod.count }}</div>
                        <div class="text-muted small">registros activos</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
