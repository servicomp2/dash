{% extends "layout.twig" %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-plus-circle-fill me-2 text-primary"></i> Nuevo {{className}}</h3>
        <nav aria-label="breadcrumb" class="mt-1">
            <ol class="breadcrumb mb-0" style="font-size:.85rem">
                <li class="breadcrumb-item"><a href="/admin/{{tableName}}">{{className}}</a></li>
                <li class="breadcrumb-item active">Crear</li>
            </ol>
        </nav>
    </div>
    <a href="/admin/{{tableName}}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-transparent border-bottom px-4 py-3">
                <h6 class="mb-0 fw-semibold text-muted"><i class="bi bi-file-earmark-text me-2"></i>Datos del Registro</h6>
            </div>
            <div class="card-body p-4">
                <form action="/admin/{{tableName}}/store" method="POST" id="createForm">
                    <div class="row g-3">
                        {{formFields}}
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                        <a href="/admin/{{tableName}}" class="btn btn-light px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">
                            <i class="bi bi-check-circle me-1"></i> Guardar Registro
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
