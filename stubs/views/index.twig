{% extends "layout.twig" %}

{% block content %}
{# Flash messages #}
{% if app.request.get('success') == 'created' %}
<div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="bi bi-check-circle-fill"></i> Registro creado exitosamente.
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
</div>
{% elseif app.request.get('success') == 'updated' %}
<div class="alert alert-info alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="bi bi-pencil-fill"></i> Registro actualizado.
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
</div>
{% elseif app.request.get('success') == 'deleted' %}
<div class="alert alert-warning alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="bi bi-trash-fill"></i> Registro eliminado.
    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-table me-2 text-primary"></i> {{className}}</h3>
        <small class="text-muted">{{ total }} registro(s) total</small>
    </div>
    <a href="/admin/{{tableName}}/create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Nuevo Registro
    </a>
</div>

{# Search bar #}
<div class="card shadow-sm border-0 mb-3">
    <div class="card-body py-2 px-3">
        <form method="GET" action="/admin/{{tableName}}" class="d-flex gap-2 align-items-center">
            <i class="bi bi-search text-muted"></i>
            <input type="text" name="q" class="form-control form-control-sm border-0 shadow-none"
                   placeholder="Buscar en {{className}}..." value="{{ q }}">
            {% if q %}
                <a href="/admin/{{tableName}}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Limpiar
                </a>
            {% endif %}
            <button type="submit" class="btn btn-sm btn-primary px-3">Buscar</button>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted text-uppercase" style="font-size: 0.72rem; letter-spacing: .05em;">
                    <tr>
                        <th class="px-4 py-3" style="width:60px">#</th>
                        {% for col in columns %}
                        <th class="px-4 py-3">{{ col|replace({'_': ' '})|capitalize }}</th>
                        {% endfor %}
                        <th class="px-4 py-3 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for record in records %}
                    <tr>
                        <td class="px-4 py-3 text-muted fw-semibold" style="font-size:.8rem">{{ record.id }}</td>
                        {% for col in columns %}
                        <td class="px-4 py-3">
                            {% if col == 'active' or col == 'status' or col == 'is_active' %}
                                <span class="badge {{ attribute(record, col) ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' }} border rounded-pill px-2">
                                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>
                                    {{ attribute(record, col) ? 'Activo' : 'Inactivo' }}
                                </span>
                            {% elseif col ends with '_at' and attribute(record, col) %}
                                <span class="text-muted" style="font-size:.85rem">{{ attribute(record, col)|date('d/m/Y H:i') }}</span>
                            {% elseif col ends with '_id' %}
                                <code class="text-secondary bg-light px-2 py-1 rounded">{{ attribute(record, col) }}</code>
                            {% elseif col == 'email' %}
                                <a href="mailto:{{ attribute(record, col) }}" class="text-decoration-none">{{ attribute(record, col) }}</a>
                            {% elseif col == 'password' %}
                                <span class="text-muted">••••••••</span>
                            {% else %}
                                {{ attribute(record, col)|default('—') }}
                            {% endif %}
                        </td>
                        {% endfor %}
                        <td class="px-4 py-3 text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <a href="/admin/{{tableName}}/{{ record.id }}/edit"
                                   class="btn btn-sm btn-outline-primary" title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form action="/admin/{{tableName}}/{{ record.id }}/delete" method="POST"
                                      class="d-inline align-self-center"
                                      onsubmit="return confirm('¿Estás seguro de que deseas eliminar este registro?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="{{ columns|length + 2 }}" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary opacity-50"></i>
                            {% if q %}
                                No se encontraron resultados para "<strong>{{ q }}</strong>".
                                <br><a href="/admin/{{tableName}}" class="text-primary mt-2 d-inline-block">Ver todos los registros</a>
                            {% else %}
                                No hay registros en {{className}} todavía.
                                <br><a href="/admin/{{tableName}}/create" class="btn btn-sm btn-primary mt-3">Crear el primero</a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% if pages > 1 %}
    <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center px-4 py-3">
        <small class="text-muted">Página {{ page }} de {{ pages }}</small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                {% if page > 1 %}
                <li class="page-item">
                    <a class="page-link" href="/admin/{{tableName}}?page={{ page - 1 }}{% if q %}&q={{ q }}{% endif %}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                {% endif %}
                {% for p in 1..pages %}
                <li class="page-item {{ p == page ? 'active' : '' }}">
                    <a class="page-link" href="/admin/{{tableName}}?page={{ p }}{% if q %}&q={{ q }}{% endif %}">{{ p }}</a>
                </li>
                {% endfor %}
                {% if page < pages %}
                <li class="page-item">
                    <a class="page-link" href="/admin/{{tableName}}?page={{ page + 1 }}{% if q %}&q={{ q }}{% endif %}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
                {% endif %}
            </ul>
        </nav>
    </div>
    {% endif %}
</div>
{% endblock %}
