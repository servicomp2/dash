# DASH-API Security - Protect sensitive files
# --------------------------------------------------

# Bloquear acceso a todo el contenido del directorio por defecto
<IfModule mod_authz_core.c>
    # Apache 2.4
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order deny,allow
    Deny from all
</IfModule>

# Permitir EXCLUSIVAMENTE el punto de entrada de la API y la documentación
<FilesMatch "^(api\.php|swagger\.html)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Allow from all
    </IfModule>
</FilesMatch>

# Bloqueo adicional para directorios de sistema (logs, vendor, git)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(\.git|logs|vendor|scripts)/ - [F,L]
</IfModule>

# Deshabilitar listado de directorios
Options -Indexes
