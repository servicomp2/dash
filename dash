#!/usr/bin/env php
<?php
declare(strict_types=1);

require_once __DIR__ . '/vendor/autoload.php';

use Dotenv\Dotenv;
use Medoo\Medoo;
use App\Core\Blueprint;
use App\Console\ScaffoldGenerator;

try {
    $dotenv = Dotenv::createImmutable(__DIR__);
    $dotenv->safeLoad();

    if (!isset($_ENV['DB_NAME'])) throw new Exception("El archivo .env no está configurado correctamente.");

    $db = new Medoo([
        'type'     => 'mysql',
        'host'     => $_ENV['DB_HOST'] ?? 'localhost',
        'database' => $_ENV['DB_NAME'],
        'username' => $_ENV['DB_USER'],
        'password' => $_ENV['DB_PASS'],
        'charset'  => 'utf8mb4',
        'port'     => (int)($_ENV['DB_PORT'] ?? 3306),
        'option'   => [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC
        ]
    ]);
} catch (\Exception $e) {
    exit("❌ Error de inicialización: " . $e->getMessage() . "\n");
}

$command = $argv[1] ?? null;
$arg1    = $argv[2] ?? null; 

switch ($command) {
    case 'make:user-auth':
        (new ScaffoldGenerator($db))->generateUserAuth($arg1 ?? 'users');
        break;
    case 'make:auth':
        (new ScaffoldGenerator($db))->generateAuth();
        break;
    case 'make:migration':
        if (!$arg1) exit("❌ Falta la tabla: php dash make:migration users\n");
        (new ScaffoldGenerator($db))->generateMigrationOnly($arg1);
        break;
    case 'make:alter':
        if (!$arg1) exit("❌ Falta la tabla a modificar: php dash make:alter branches\n");
        (new ScaffoldGenerator($db))->generateAlterMigration($arg1);
        break;
    case 'make:scaffold':
        if (!$arg1) exit("❌ Falta el archivo JSON: php dash make:scaffold schema.json\n");
        (new ScaffoldGenerator($db))->generateFromJson($arg1);
        break;
    case 'scaffold:db':
        if (!$arg1) exit("❌ Falta la tabla: php dash scaffold:db auth_users\n");
        (new ScaffoldGenerator($db))->generateFromDb($arg1);
        break;
    case 'swagger:generate':
        generateSwagger();
        break;
    case 'migrate':
        runMigrations($db);
        break;
    case 'rollback':
        rollbackMigration($db);
        break;
    default:
        echo "🚀 DASH ADVANCED CLI:\n";
        echo "  make:auth                   (Instala la capa base de Seguridad, Register y Login)\n";
        echo "  make:user-auth <tableName>  (Instala el módulo de seguridad para Usuarios de la App)\n";
        echo "  make:migration <tableName>  (Genera un archivo vacío de migración SQL para CREATE TABLE)\n";
        echo "  make:alter <tableName>      (Genera un archivo de migración para ALTER TABLE)\n";
        echo "  make:scaffold <file.json>   (Andamiaje MVC+API desde JSON)\n";
        echo "  scaffold:db <tableName>     (Introspección MVC+API desde MariaDB)\n";
        echo "  swagger:generate            (Escanea App y actualiza public/swagger.json)\n";
        echo "  migrate                     (Ejecuta migraciones pendientes y auto-genera MVC y Swagger)\n";
        echo "  rollback                    (Deshace la última migración y borra TODOS sus archivos)\n";
        break;
}

function runMigrations(Medoo $db): void {
    $db->query("CREATE TABLE IF NOT EXISTS migrations (id INT AUTO_INCREMENT PRIMARY KEY, migration VARCHAR(255) NOT NULL, applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP)");
    
    $files = glob(__DIR__ . '/database/migrations/*.php');
    sort($files);
    $count = 0;

    foreach ($files as $file) {
        $basename = basename($file);
        if (!$db->has("migrations", ["migration" => $basename])) {
            $content = file_get_contents($file);
            if (preg_match('/class\s+([a-zA-Z0-9_]+)/', $content, $matches)) {
                $className = $matches[1];
            } else {
                continue;
            }

            require_once $file;
            if (!class_exists($className)) continue;

            $migration = new $className();
            $blueprint = new Blueprint($migration->table);
            $migration->up($blueprint);

            // Soporte para migraciones ALTER TABLE via getRawSql()
            if (method_exists($migration, 'getRawSql')) {
                $sql = $migration->getRawSql();
            } else {
                $sql = $blueprint->toSql();
            }

            try {
                $db->query($sql);
                $db->insert("migrations", ["migration" => $basename]);
                echo "✅ Migración Aplicada: {$basename}\n";
                
                echo "⚙️ Auto-generando componentes a partir de la nueva tabla...\n";
                (new ScaffoldGenerator($db))->generateFromDb($migration->table, $migration, $blueprint);

                $count++;
            } catch (\Exception $e) {
                exit("❌ Error SQL en {$basename}: " . $e->getMessage() . "\n");
            }
        }
    }
    
    if ($count > 0) {
        echo "🚀 Actualización completada.\n";
        generateSwagger();
    } else {
        echo "ℹ️ No hay cambios pendientes.\n";
    }
}

function rollbackMigration(Medoo $db): void {
    $last = $db->get("migrations", ['migration', 'id'], ["ORDER" => ["id" => "DESC"]]);
    if (!$last) exit("ℹ️ Nada que revertir.\n");

    $file = __DIR__ . '/database/migrations/' . $last['migration'];
    if (!file_exists($file)) {
        echo "⚠️ Archivo de migración perdido: {$last['migration']}. Limpiando registro de DB...\n";
        $db->delete("migrations", ["id" => $last['id']]);
        return;
    }

    $content = file_get_contents($file);
    if (preg_match('/class\s+([a-zA-Z0-9_]+)/', $content, $matches)) {
        $className = $matches[1];
    } else {
        exit("❌ Clase corrupta.\n");
    }

    require_once $file;
    $migration = new $className();
    $blueprint = new Blueprint($migration->table);
    $migration->down($blueprint);
    
    // Determinar SQL: prioritizar toSql si es ALTER, sino dropTable si fue solicitado
    if ($blueprint->isDropTable()) {
        $sql = $blueprint->dropTable();
        $isCreate = true;
    } elseif ($blueprint->isAlter()) {
        $sql = $blueprint->toSql();
        $isCreate = false;
    } else {
        // Por defecto para migraciones estándar de creación
        $sql = $blueprint->dropTable();
        $isCreate = true;
    }

    try {
        if ($sql) $db->query($sql);
        $table = $migration->table;
        $classN = ucfirst($table);

        if ($isCreate) {
            echo "🗑️ Eliminando andamiaje de la tabla: {$table}...\n";
            // Delete new generator files
            @unlink(__DIR__ . "/app/Controllers/Api/{$classN}Controller.php");
            @unlink(__DIR__ . "/app/Controllers/Web/{$classN}Controller.php");
            @unlink(__DIR__ . "/routes/api_modules/{$table}.php");
            @unlink(__DIR__ . "/routes/web_modules/{$table}.php");
            
            // Remove View folder
            $viewsDir = __DIR__ . "/app/Views/{$table}";
            if (is_dir($viewsDir)) {
                array_map('unlink', glob("$viewsDir/*.*"));
                @rmdir($viewsDir);
            }

            // Clean layout.twig Sidebar
            $layoutDest = __DIR__ . '/app/Views/layout.twig';
            if (file_exists($layoutDest)) {
                $layoutC = file_get_contents($layoutDest);
                $pattern = '/<li class="nav-item">\s*<a class="nav-link[^"]*" href="\/admin\/' . preg_quote($table, '/') . '"[^>]*>.*?<\/li>/is';
                $cleanedLayout = preg_replace($pattern, '', $layoutC);
                file_put_contents($layoutDest, $cleanedLayout);
            }

            // Clean api.php injection
            $apiP = __DIR__ . '/routes/api.php';
            if (file_exists($apiP)) {
                $apiContent = file_get_contents($apiP);
                $apiContent = preg_replace('/^[ \t]*require_once __DIR__ \. \'\/api_modules\/' . $table . '\.php\';\r?\n?/m', '', $apiContent);
                file_put_contents($apiP, $apiContent);
            }

            // Clean web.php injection
            $webP = __DIR__ . '/routes/web.php';
            if (file_exists($webP)) {
                $webContent = file_get_contents($webP);
                $webContent = preg_replace('/^[ \t]*require_once __DIR__ \. \'\/web_modules\/' . $table . '\.php\';\r?\n?/m', '', $webContent);
                file_put_contents($webP, $webContent);
            }
            
            if ($table === 'superadmin') {
                @unlink(__DIR__ . '/app/Controllers/Api/AuthController.php');
            }
            if ($table === 'usuarios' || $table === 'users') {
                @unlink(__DIR__ . '/app/Controllers/Api/UserAuthController.php');
            }
        } else {
            echo "⚙️ Re-generando andamiaje previo para: {$table}...\n";
            (new ScaffoldGenerator($db))->generateFromDb($table);
        }
        
        unlink($file); // Delete the migration file
        $db->delete("migrations", ["id" => $last['id']]);
        echo "✅ Rollback completado de: " . ($isCreate ? "Tabla " : "Alteración ") . "{$table}\n";
        
        generateSwagger();
    } catch (\Exception $e) {
        exit("❌ Error SQL: " . $e->getMessage() . "\n");
    }
}

function generateSwagger(): void {
    echo "🔎 Escaneando rutas y modelos API...\n";
    error_reporting(E_ALL & ~E_USER_WARNING & ~E_USER_NOTICE); // Evitar warnings de rutas por stubs incompletos
    try {
        $openapi = (new \OpenApi\Generator())->generate([
            __DIR__ . '/app/Controllers/Api',
            __DIR__ . '/app/Core'
        ]);
        $json = $openapi->toJson();
        $path = __DIR__ . '/public/swagger.json';
        file_put_contents($path, $json);
        echo "✅ Schema OpenAPI generado en {$path}\n";
        echo "🔗 Visítalo en: /docs/\n";
    } catch (\Exception $e) {
        echo "❌ Falla al compilar Swagger: " . $e->getMessage() . "\n";
    }
}